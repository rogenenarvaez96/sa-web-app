<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Repair Shop</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<nav class="navbar navbar-dark bg-dark px-4">
  <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/jobs">
    <% if (locals.logoFile) { %>
  <img src="<%= logoFile %>" alt="Logo" style="max-height:32px;"/>
<% } %>
<%= locals.shopName || 'Repair Shop' %>
  </a>
  <div class="d-flex align-items-center gap-3">
    <% if (locals.user) { %>
      <span class="text-white-50 small">
        👤 <%= user.username %>
        <span class="badge bg-<%= user.role === 'admin' ? 'danger' : user.role === 'technician' ? 'primary' : 'secondary' %> ms-1">
          <%= user.role %>
        </span>
      </span>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="btn btn-outline-light btn-sm">⚙ Admin</a>
      <% } %>
      <% if (user.role === 'admin' || user.role === 'technician') { %>
        <a href="/jobs/new" class="btn btn-warning btn-sm">+ New Job</a>
      <% } %>
      <form action="/auth/logout" method="POST" class="mb-0">
        <button class="btn btn-outline-danger btn-sm">Logout</button>
      </form>
    <% } %>
  </div>
</nav>
<div class="container-fluid mt-4">